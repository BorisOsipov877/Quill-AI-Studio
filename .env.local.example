# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: used by the Server Action to write generations, bypassing RLS.
# Never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (server-only) — REQUIRED. The generator calls the real
# Messages API; without this key every generation fails with a friendly error.
# On Vercel: Project Settings → Environment Variables.
ANTHROPIC_API_KEY=
